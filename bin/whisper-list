#!/usr/bin/env bash
set -euo pipefail

WHISPER_DIR="${WHISPER_DIR:-$HOME/.claude-whisper}"
PEERS_FILE="$WHISPER_DIR/peers.json"
WARN_DIR="$WHISPER_DIR/state/warnings"
STALE_DAYS="${WHISPER_STALE_DAYS:-7}"

[ ! -f "$PEERS_FILE" ] && { echo "No peers registered." >&2; exit 1; }

# Read own peer-id
SELF=""
if [ -f ".whisper-peer" ]; then
  SELF=$(cat ".whisper-peer")
fi

# Surface fail-loud warnings written by check-inbox.sh (R2)
shopt -s nullglob
WARN_FILES=("$WARN_DIR"/*.warn)
shopt -u nullglob
if [ ${#WARN_FILES[@]} -gt 0 ]; then
  echo "⚠️  ${#WARN_FILES[@]} warning(s) — run \`whisper-doctor\` for details:"
  for w in "${WARN_FILES[@]}"; do
    echo "  - $(basename "$w")"
  done
  echo
fi

# Compute stale cutoff in epoch seconds. macOS date(1) doesn't support -d, so
# we use -j -f. Fall back to "no stale check" if the date math fails.
NOW_EPOCH=$(date +%s)
STALE_CUTOFF=$((NOW_EPOCH - STALE_DAYS * 86400))

echo "| Peer | Project | Last seen | Inbox |"
echo "|------|---------|-----------|-------|"

jq -r '.peers | to_entries[] | "\(.key)\t\(.value.cwd // "-")\t\(.value.last_seen // "-")"' "$PEERS_FILE" | \
while IFS=$'\t' read -r id cwd last_seen; do
  # Count pending messages
  INBOX="$WHISPER_DIR/inbox/$id"
  PENDING=0
  if [ -d "$INBOX" ]; then
    PENDING=$(find "$INBOX" -name 'msg-*.json' 2>/dev/null | grep -c . 2>/dev/null || true)
    [ -z "$PENDING" ] && PENDING=0
  fi

  # Mark self
  MARKER=""
  if [ "$id" = "$SELF" ]; then
    MARKER=" **(you)**"
  fi

  # Format last_seen + stale check
  SHORT_TS=$(echo "$last_seen" | sed 's/.*T\([0-9]*:[0-9]*\).*/\1/' 2>/dev/null)
  STALE_TAG=""
  if [ "$last_seen" != "-" ] && [ -n "$last_seen" ]; then
    # Try to parse as ISO-8601 UTC. macOS: date -j -f. Linux: date -d.
    LS_EPOCH=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$last_seen" "+%s" 2>/dev/null || \
               date -u -d "$last_seen" "+%s" 2>/dev/null || echo "")
    if [ -n "$LS_EPOCH" ] && [ "$LS_EPOCH" -lt "$STALE_CUTOFF" ]; then
      STALE_TAG=" ⚠️ stale"
    fi
  fi

  DISPLAY_CWD=$(echo "$cwd" | sed "s|^$HOME|~|")
  echo "| **${id}**${MARKER} | ${DISPLAY_CWD} | ${SHORT_TS}${STALE_TAG} | ${PENDING} |"
done
