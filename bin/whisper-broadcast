#!/usr/bin/env bash
set -euo pipefail

WHISPER_DIR="${WHISPER_DIR:-$HOME/.claude-whisper}"
SELF_BIN="$(cd "$(dirname "$0")" && pwd)"

usage() { echo "Usage: whisper-broadcast <message>" >&2; exit 1; }

[ $# -lt 1 ] && usage
CONTENT="$*"

# Read own peer-id from project directory
if [ -f ".whisper-peer" ]; then
  FROM=$(cat ".whisper-peer")
else
  echo "Error: not initialized. Run whisper-init first." >&2; exit 1
fi

PEERS_FILE="$WHISPER_DIR/peers.json"
[ ! -f "$PEERS_FILE" ] && { echo "Error: no peers registered." >&2; exit 1; }

# Get all peer-ids except self
TARGETS=$(jq -r --arg self "$FROM" '.peers | keys[] | select(. != $self)' "$PEERS_FILE" 2>/dev/null)
[ -z "$TARGETS" ] && { echo "No other peers to broadcast to." >&2; exit 0; }

COUNT=0
for peer in $TARGETS; do
  bash "$SELF_BIN/whisper-send" "$peer" "$CONTENT" && COUNT=$((COUNT + 1))
done

echo "📢 whisper broadcast → ${COUNT} peer(s): ${TARGETS//$'\n'/, }"
