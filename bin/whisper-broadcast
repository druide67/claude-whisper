#!/usr/bin/env bash
set -euo pipefail

WHISPER_DIR="${WHISPER_DIR:-$HOME/.claude-whisper}"
SELF_BIN="$(cd "$(dirname "$0")" && pwd)"

usage() { echo "Usage: whisper-broadcast [-t thread] [-f from] <message>" >&2; exit 1; }

# Parse optional flags
THREAD=""
FROM_OVERRIDE=""
while [ $# -gt 0 ]; do
  case "$1" in
    -t|--thread) THREAD="$2"; shift 2 ;;
    -f|--from) FROM_OVERRIDE="$2"; shift 2 ;;
    *) break ;;
  esac
done

[ $# -lt 1 ] && usage
CONTENT="$*"

# Read own peer-id: --from flag > .whisper-peer file
if [ -n "$FROM_OVERRIDE" ]; then
  FROM="$FROM_OVERRIDE"
elif [ -f ".whisper-peer" ]; then
  FROM=$(cat ".whisper-peer")
else
  echo "Error: not initialized. Run whisper-init or use --from." >&2; exit 1
fi

PEERS_FILE="$WHISPER_DIR/peers.json"
[ ! -f "$PEERS_FILE" ] && { echo "Error: no peers registered." >&2; exit 1; }

# Get all peer-ids except self
TARGETS=$(jq -r --arg self "$FROM" '.peers | keys[] | select(. != $self)' "$PEERS_FILE" 2>/dev/null)
[ -z "$TARGETS" ] && { echo "No other peers to broadcast to." >&2; exit 0; }

# Build flags to pass through
FLAGS=""
[ -n "$THREAD" ] && FLAGS="-t $THREAD"
[ -n "$FROM_OVERRIDE" ] && FLAGS="$FLAGS -f $FROM_OVERRIDE"

COUNT=0
for peer in $TARGETS; do
  bash "$SELF_BIN/whisper-send" $FLAGS "$peer" "$CONTENT" && COUNT=$((COUNT + 1))
done

echo "📢 whisper broadcast → ${COUNT} peer(s): ${TARGETS//$'\n'/, }"
