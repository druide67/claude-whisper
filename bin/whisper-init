#!/usr/bin/env bash
set -euo pipefail

WHISPER_DIR="${WHISPER_DIR:-$HOME/.claude-whisper}"

usage() { echo "Usage: whisper-init <peer-id> [project-dir]" >&2; exit 1; }

[ $# -lt 1 ] && usage
PEER_ID="$1"
PROJECT_DIR="${2:-$(pwd)}"

# Validate peer-id: alphanumeric + dash only
if [[ ! "$PEER_ID" =~ ^[a-zA-Z0-9-]+$ ]]; then
  echo "Error: peer-id must be alphanumeric + dash (got: $PEER_ID)" >&2
  exit 1
fi

# Locate repo hooks (relative to this script)
REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Create directory structure
mkdir -p "$WHISPER_DIR/inbox/$PEER_ID" "$WHISPER_DIR/archive" "$WHISPER_DIR/hooks"
chmod 700 "$WHISPER_DIR" "$WHISPER_DIR/inbox" "$WHISPER_DIR/archive" "$WHISPER_DIR/hooks"

# Copy hooks from repo
cp "$REPO_DIR/hooks/check-inbox.sh" "$WHISPER_DIR/hooks/"
chmod 700 "$WHISPER_DIR/hooks/check-inbox.sh"

# Register peer-id in project directory
echo "$PEER_ID" > "$PROJECT_DIR/.whisper-peer"

# Update peers.json with project path
PEERS_FILE="$WHISPER_DIR/peers.json"
NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
if [ -f "$PEERS_FILE" ]; then
  jq --arg id "$PEER_ID" --arg ts "$NOW" --arg cwd "$PROJECT_DIR" \
    '.peers[$id].registered //= $ts | .peers[$id].last_seen = $ts | .peers[$id].cwd = $cwd' \
    "$PEERS_FILE" > "$PEERS_FILE.tmp" && mv "$PEERS_FILE.tmp" "$PEERS_FILE"
else
  jq -n --arg id "$PEER_ID" --arg ts "$NOW" --arg cwd "$PROJECT_DIR" \
    '{peers: {($id): {registered: $ts, last_seen: $ts, cwd: $cwd}}}' > "$PEERS_FILE"
fi
chmod 600 "$PEERS_FILE"

# Inject hook into ~/.claude/settings.json (skip if WHISPER_DIR is overridden)
SETTINGS="$HOME/.claude/settings.json"
HOOK_CMD="bash $WHISPER_DIR/hooks/check-inbox.sh"

if [ "$WHISPER_DIR" != "$HOME/.claude-whisper" ]; then
  HOOK_STATUS="skipped (custom WHISPER_DIR)"
elif [ -f "$SETTINGS" ]; then
  if jq -e --arg cmd "$HOOK_CMD" '.hooks.UserPromptSubmit[]?.hooks[]? | select(.command == $cmd)' "$SETTINGS" > /dev/null 2>&1; then
    HOOK_STATUS="already configured"
  else
    jq --arg cmd "$HOOK_CMD" '
      .hooks //= {} |
      .hooks.UserPromptSubmit //= [] |
      .hooks.UserPromptSubmit += [{"matcher": "", "hooks": [{"type": "command", "command": $cmd}]}]
    ' "$SETTINGS" > "$SETTINGS.tmp" && mv "$SETTINGS.tmp" "$SETTINGS"
    HOOK_STATUS="installed"
  fi
else
  echo "Warning: $SETTINGS not found." >&2
  HOOK_STATUS="skipped"
fi

# Create symlinks in ~/.local/bin/ (skip if WHISPER_DIR is overridden)
BIN_DIR="$HOME/.local/bin"
if [ "$WHISPER_DIR" != "$HOME/.claude-whisper" ]; then
  SYMLINK_STATUS="skipped (custom WHISPER_DIR)"
else
  mkdir -p "$BIN_DIR"
  SYMLINK_STATUS="linked"
  for cmd in whisper-init whisper-send whisper-broadcast whisper-list whisper-clean; do
    ln -sf "$REPO_DIR/bin/$cmd" "$BIN_DIR/$cmd"
  done
fi

echo "📡 Whisper initialized"
echo "   Peer: $PEER_ID"
echo "   Project: $PROJECT_DIR"
echo "   Hook: $HOOK_STATUS"
echo "   Commands: $SYMLINK_STATUS → $BIN_DIR/"
echo ""
echo "── Onboarding prompt (copy-paste into Claude Code) ──"
echo ""
cat <<ONBOARDING
You are connected to whisper, a peer-to-peer messaging system for Claude Code instances.
Your peer-id is "$PEER_ID". Available commands:
- whisper-send <peer> "msg" — send a message directly to a peer
- whisper-send -t <thread> <peer> "msg" — send with a thread tag
- whisper-broadcast "msg" — send to all registered peers
- whisper-list — list active peers and their inbox status
- whisper-clean [days] — remove archived messages older than N days (default: 7)
Important: whisper is peer-to-peer. Send messages directly to the target peer-id, not to a hub.
Run whisper-list to see available peers. Messages arrive automatically at each prompt via the hook.
Save these commands to your memory for future conversations.
ONBOARDING

echo ""
echo "── Active peers ──"
echo ""
bash "$REPO_DIR/bin/whisper-list" 2>/dev/null || true
