#!/usr/bin/env bash
set -euo pipefail

WHISPER_DIR="${WHISPER_DIR:-$HOME/.claude-whisper}"

usage() { echo "Usage: whisper-send [-t thread] [-f from] <peer-id> <message>" >&2; exit 1; }

# Parse optional flags
THREAD=""
FROM_OVERRIDE=""
while [ $# -gt 0 ]; do
  case "$1" in
    -t|--thread) THREAD="$2"; shift 2 ;;
    -f|--from) FROM_OVERRIDE="$2"; shift 2 ;;
    *) break ;;
  esac
done

[ $# -lt 2 ] && usage
TO="$1"; shift
CONTENT="$*"

# Validate peer-id
if [[ ! "$TO" =~ ^[a-zA-Z0-9-]+$ ]]; then
  echo "Error: peer-id must be alphanumeric + dash (got: $TO)" >&2
  exit 1
fi

# Reject empty messages
[ -z "$CONTENT" ] && { echo "Error: message cannot be empty." >&2; exit 1; }

# Read sender identity: --from flag > .whisper-peer file
if [ -n "$FROM_OVERRIDE" ]; then
  FROM="$FROM_OVERRIDE"
elif [ -f ".whisper-peer" ]; then
  FROM=$(cat ".whisper-peer")
else
  echo "Error: not initialized. Run whisper-init or use --from." >&2; exit 1
fi

# Validate sender identity
if [[ ! "$FROM" =~ ^[a-zA-Z0-9-]+$ ]]; then
  echo "Error: corrupted .whisper-peer (got: $FROM)" >&2; exit 1
fi

# Warn if recipient is unknown
PEERS_FILE="$WHISPER_DIR/peers.json"
if [ -f "$PEERS_FILE" ] && ! jq -e --arg to "$TO" '.peers[$to]' "$PEERS_FILE" > /dev/null 2>&1; then
  echo "⚠️  Warning: peer '$TO' is not in peers.json. Run whisper-list to see known peers." >&2
fi

# ---- G2: anti-duplicate within DUP_WINDOW seconds (default 30) -----------
DUP_WINDOW="${WHISPER_DUP_WINDOW:-30}"
STATE_DIR="$WHISPER_DIR/state"
mkdir -p "$STATE_DIR" 2>/dev/null || true
RECENT_SENDS="$STATE_DIR/recent-sends.json"

CONTENT_HASH=$(printf '%s' "$CONTENT" | shasum -a 256 | cut -c1-16)
DUP_KEY="${FROM}|${TO}|${CONTENT_HASH}"
NOW_TS=$(date +%s)

if [ -f "$RECENT_SENDS" ]; then
  IS_DUP=$(jq --arg key "$DUP_KEY" --argjson now "$NOW_TS" --argjson window "$DUP_WINDOW" \
    '[.entries[]? | select(.key == $key and (.ts > ($now - $window)))] | length' \
    "$RECENT_SENDS" 2>/dev/null || echo 0)
  if [ "$IS_DUP" -gt 0 ]; then
    echo "⚠️  whisper-send: duplicate within ${DUP_WINDOW}s — refused (hash=${CONTENT_HASH})" >&2
    exit 0
  fi
fi

# Append entry, prune entries older than window
if [ -f "$RECENT_SENDS" ]; then
  jq --arg key "$DUP_KEY" --argjson now "$NOW_TS" --argjson window "$DUP_WINDOW" \
    '{entries: ((.entries // []) + [{ts: $now, key: $key}] | map(select(.ts > ($now - $window))))}' \
    "$RECENT_SENDS" > "$RECENT_SENDS.tmp" 2>/dev/null || \
    printf '{"entries":[{"ts":%s,"key":"%s"}]}\n' "$NOW_TS" "$DUP_KEY" > "$RECENT_SENDS.tmp"
else
  printf '{"entries":[{"ts":%s,"key":"%s"}]}\n' "$NOW_TS" "$DUP_KEY" > "$RECENT_SENDS.tmp"
fi
chmod 600 "$RECENT_SENDS.tmp"
mv "$RECENT_SENDS.tmp" "$RECENT_SENDS"

# ---- G3: hop_count for thread loop protection ----------------------------
HOP_COUNT=0
if [ -n "$THREAD" ]; then
  # Sentinel -1 means "thread never seen yet" — first message stays at hop 0
  MAX_HOP=-1
  for dir in "$WHISPER_DIR/archive" "$WHISPER_DIR/inbox/$TO" "$WHISPER_DIR/inbox/$FROM" "$WHISPER_DIR/run/processing"; do
    [ -d "$dir" ] || continue
    shopt -s nullglob
    for f in "$dir"/msg-*.json; do
      [ -f "$f" ] || continue
      MSG_THREAD=$(jq -r '.thread // ""' "$f" 2>/dev/null || echo "")
      if [ "$MSG_THREAD" = "$THREAD" ]; then
        H=$(jq -r '.hop_count // 0' "$f" 2>/dev/null || echo 0)
        [ "$H" -gt "$MAX_HOP" ] && MAX_HOP=$H
      fi
    done
    shopt -u nullglob
  done
  if [ "$MAX_HOP" -ge 0 ]; then
    HOP_COUNT=$((MAX_HOP + 1))
  fi
fi

# Ensure recipient inbox exists
mkdir -p "$WHISPER_DIR/inbox/$TO"

# Build message
NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
TS=$(date +%s)
RAND=$(head -c 4 /dev/urandom | od -An -tx1 | tr -d ' \n')
MSG_ID="msg-${TS}-${RAND}"
MSG_FILE="$WHISPER_DIR/inbox/$TO/${MSG_ID}.json"

jq -n \
  --arg id "$MSG_ID" \
  --arg from "$FROM" \
  --arg to "$TO" \
  --arg ts "$NOW" \
  --arg content "$CONTENT" \
  --arg thread "$THREAD" \
  --argjson hop "$HOP_COUNT" \
  '{id: $id, from: $from, to: $to, timestamp: $ts, content: $content, priority: "normal", ttl: 3600, hop_count: $hop} | if $thread != "" then .thread = $thread else . end' \
  > "${MSG_FILE}.tmp"

chmod 600 "${MSG_FILE}.tmp"
mv "${MSG_FILE}.tmp" "$MSG_FILE"

THREAD_INFO=""
[ -n "$THREAD" ] && THREAD_INFO=" [${THREAD} hop=${HOP_COUNT}]"
echo "📤 whisper → ${TO}${THREAD_INFO}: message envoyé ($MSG_ID)"
