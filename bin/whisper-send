#!/usr/bin/env bash
set -euo pipefail

WHISPER_DIR="${WHISPER_DIR:-$HOME/.claude-whisper}"

usage() { echo "Usage: whisper-send [-t thread] [-f from] <peer-id> <message>" >&2; exit 1; }

# Parse optional flags
THREAD=""
FROM_OVERRIDE=""
while [ $# -gt 0 ]; do
  case "$1" in
    -t|--thread) THREAD="$2"; shift 2 ;;
    -f|--from) FROM_OVERRIDE="$2"; shift 2 ;;
    *) break ;;
  esac
done

[ $# -lt 2 ] && usage
TO="$1"; shift
CONTENT="$*"

# Validate peer-id
if [[ ! "$TO" =~ ^[a-zA-Z0-9-]+$ ]]; then
  echo "Error: peer-id must be alphanumeric + dash (got: $TO)" >&2
  exit 1
fi

# Reject empty messages
[ -z "$CONTENT" ] && { echo "Error: message cannot be empty." >&2; exit 1; }

# Read sender identity: --from flag > .whisper-peer file
if [ -n "$FROM_OVERRIDE" ]; then
  FROM="$FROM_OVERRIDE"
elif [ -f ".whisper-peer" ]; then
  FROM=$(cat ".whisper-peer")
else
  echo "Error: not initialized. Run whisper-init or use --from." >&2; exit 1
fi

# Validate sender identity
if [[ ! "$FROM" =~ ^[a-zA-Z0-9-]+$ ]]; then
  echo "Error: corrupted .whisper-peer (got: $FROM)" >&2; exit 1
fi

# Warn if recipient is unknown
PEERS_FILE="$WHISPER_DIR/peers.json"
if [ -f "$PEERS_FILE" ] && ! jq -e --arg to "$TO" '.peers[$to]' "$PEERS_FILE" > /dev/null 2>&1; then
  echo "⚠️  Warning: peer '$TO' is not in peers.json. Run whisper-list to see known peers." >&2
fi

# Ensure recipient inbox exists
mkdir -p "$WHISPER_DIR/inbox/$TO"

# Build message
NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
TS=$(date +%s)
RAND=$(head -c 4 /dev/urandom | od -An -tx1 | tr -d ' \n')
MSG_ID="msg-${TS}-${RAND}"
MSG_FILE="$WHISPER_DIR/inbox/$TO/${MSG_ID}.json"

jq -n \
  --arg id "$MSG_ID" \
  --arg from "$FROM" \
  --arg to "$TO" \
  --arg ts "$NOW" \
  --arg content "$CONTENT" \
  --arg thread "$THREAD" \
  '{id: $id, from: $from, to: $to, timestamp: $ts, content: $content, priority: "normal", ttl: 3600} | if $thread != "" then .thread = $thread else . end' \
  > "${MSG_FILE}.tmp"

chmod 600 "${MSG_FILE}.tmp"
mv "${MSG_FILE}.tmp" "$MSG_FILE"

THREAD_INFO=""
[ -n "$THREAD" ] && THREAD_INFO=" [${THREAD}]"
echo "📤 whisper → ${TO}${THREAD_INFO}: message envoyé ($MSG_ID)"
